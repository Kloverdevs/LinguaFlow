{
  "name": "linguaflow",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite build --watch\" \"vite build --watch --config vite.content.config.ts\" \"vite build --watch --config vite.background.config.ts\"",
    "build": "npm run clean && vite build && vite build --config vite.content.config.ts && vite build --config vite.background.config.ts && npm run copy-manifest",
    "clean": "rimraf dist",
    "copy-manifest": "copyfiles -u 1 \"public/**/*\" dist",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "copyfiles": "^2.4.1",
    "eslint": "^9.0.0",
    "jsdom": "^28.1.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
